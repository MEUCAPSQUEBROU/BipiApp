# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Distribuição: ignora os binários gerados (APK, QR, banner)...
/dist/*
# ...mas versiona os scripts geradores (release.ps1, make_qr.py, make_banner.py).
!/dist/*.ps1
!/dist/*.py

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Sessões do compilador Kotlin (geradas pelo Gradle build)
android/.kotlin/

# Firebase — contém API key e config do projeto; manter fora do repo.
# Ao clonar/trocar de máquina: re-baixar do Console do Firebase
# (Configurações do projeto > Seus apps > app Android) e colocar em android/app/.
android/app/google-services.json

# Backup das imagens originais (com fundo / fonte). As versões usadas no app
# ficam fora de _originais/ e são versionadas.
assets/mascote/_originais/
assets/icon/_originais/
